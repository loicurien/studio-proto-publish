{
  "name": "studio-proto-publish",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal NestJS backend for prototype publishing, deployed on Railway.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "postinstall": "prisma generate",
    "migrate:from-sqlite": "ts-node scripts/migrate-from-sqlite.ts"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@types/node": "^22.15.3",
    "prisma": "^6.3.1",
    "@prisma/client": "^6.3.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}

